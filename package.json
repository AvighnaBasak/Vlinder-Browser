{
  "name": "vlinder",
  "productName": "Vlinder",
  "version": "2.0.0",
  "description": "Vlinder - The best open-source Electron browser. Privacy-focused desktop web browser with built-in ad blocker, Tor proxy, incognito mode, password manager, tab groups, split screen, and customizable themes. A lightweight, low-memory alternative to Chrome built with Electron, React, and TypeScript.",
  "keywords": [
    "electron",
    "electron-browser",
    "electron-based-browser",
    "electron-web-browser",
    "electron-desktop-browser",
    "browser",
    "web-browser",
    "desktop-browser",
    "open-source-browser",
    "privacy-browser",
    "ad-blocker",
    "adblocker",
    "content-blocker",
    "youtube-ad-blocker",
    "tor",
    "tor-proxy",
    "tor-browser",
    "vpn",
    "anonymity",
    "incognito",
    "private-browsing",
    "privacy",
    "password-manager",
    "download-manager",
    "tab-groups",
    "split-screen",
    "tabs",
    "react",
    "typescript",
    "tailwindcss",
    "vite",
    "chromium",
    "chrome-alternative",
    "brave-alternative",
    "firefox-alternative",
    "lightweight-browser",
    "low-memory-browser",
    "minimal-browser",
    "windows",
    "macos",
    "linux",
    "cross-platform",
    "themes",
    "customizable",
    "transparency",
    "acrylic"
  ],
  "main": "./out/main/main.js",
  "license": "GPL-3.0-only",
  "author": {
    "name": "Avighna Basak",
    "url": "https://github.com/AvighnaBasak"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AvighnaBasak/Vlinder-Browser"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --win",
    "dist:dir": "electron-vite build && electron-builder --win --dir"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@ghostery/adblocker-electron": "^2.5.2",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-dl-manager": "^4.2.0",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.1.7",
    "keytar": "^7.9.0",
    "lucide-react": "^0.541.0",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.7",
    "zod": "^4.1.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^9.34.0",
    "@rushstack/eslint-patch": "^1.12.0",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.8",
    "@vitejs/plugin-react": "^5.0.1",
    "cross-env": "^10.0.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "framer-motion": "^12.23.12",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.avighnabasak.vlinder",
    "productName": "Vlinder",
    "artifactName": "Vlinder-Setup-${version}.${ext}",
    "copyright": "Copyright © 2025 Avighna Basak",
    "directories": {
      "output": "dist",
      "buildResources": "resources/build"
    },
    "files": [
      "out/**/*",
      "!node_modules/**/*",
      "node_modules/**/*.js",
      "node_modules/**/*.json",
      "node_modules/**/*.node",
      "node_modules/**/*.wasm",
      "!demoimg",
      "!demoimg/**/*",
      "!ui-ref",
      "!ui-ref/**/*",
      "!min-master",
      "!min-master/**/*",
      "!scripts",
      "!scripts/**/*",
      "!*.md",
      "!CLAUDE.md"
    ],
    "extraResources": [
      {
        "from": "resources/build/default-app",
        "to": "default-app",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/build/icon.ico",
      "uninstallerIcon": "resources/build/icon.ico",
      "installerHeaderIcon": "resources/build/icon.ico",
      "installerSidebar": null,
      "uninstallDisplayName": "Vlinder Browser",
      "shortcutName": "Vlinder",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "Internet",
      "include": "resources/build/installer.nsh",
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "target": ["dmg"],
      "icon": "resources/build/icon.png",
      "category": "public.app-category.utilities",
      "entitlements": "resources/build/entitlements.mac.plist",
      "entitlementsInherit": "resources/build/entitlements.mac.plist"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "resources/build/icon.png",
      "category": "Network;WebBrowser",
      "mimeTypes": [
        "text/html",
        "text/xml",
        "application/xhtml+xml",
        "x-scheme-handler/http",
        "x-scheme-handler/https"
      ]
    }
  }
}
