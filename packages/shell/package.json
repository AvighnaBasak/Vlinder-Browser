{
  "name": "shell",
  "productName": "Shell",
  "version": "2.2.0",
  "description": "Minimum Viable Browser shell built on NW.js with full Chromium compatibility.",
  "main": "browser/ui/webui.html",
  "window": {
    "title": "Shell Browser",
    "width": 1280,
    "height": 720,
    "min_width": 800,
    "min_height": 600,
    "frame": false,
    "toolbar": false,
    "transparent": false,
    "show": true,
    "position": "center"
  },
  "chromium-args": "--enable-extensions --ignore-certificate-errors --allow-file-access-from-files --disable-web-security --enable-experimental-web-platform-features --enable-features=NativeFileSystemAPI,FileHandlingAPI --disable-features=CrossOriginOpenerPolicy",
  "node-remote": "<all_urls>",
  "webkit": {
    "plugin": true
  },
  "scripts": {
    "start": "nw .",
    "build": "echo 'NW.js build - TBD'",
    "package": "echo 'NW.js package - TBD'"
  },
  "license": "MIT",
  "author": "Samuel Maddock <sam@samuelmaddock.com>",
  "private": true,
  "dependencies": {
    "animejs": "^4.1.4",
    "keytar": "^7.9.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nw": "^0.104.1"
  }
}
