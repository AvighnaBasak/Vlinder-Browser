{
  "name": "WebUI",
  "version": "1.0.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "webRequest", "webRequestBlocking", "downloads", "storage", "<all_urls>"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": [
        "webui.html",
        "webui.js",
        "webui-main.js",
        "history.html",
        "history.js",
        "history-data.json",
        "downloads.html",
        "downloads.js",
        "downloads-data.json",
        "bookmarks.html",
        "bookmarks.js",
        "bookmarks-data.json",
        "new-tab.html",
        "new-tab.js",
        "search.png",
        "dns-error.html",
        "no-internet.html",
        "dnserror.png",
        "selected-star.png",
        "unselected-star.png",
        "theme-loader.js",
        "current-theme.json",
        "background-settings.json",
        "ai-chat.js",
        "ai-chat.css",
        "backgrounds/*",
        "*.png",
        "*.jpg",
        "*.webp"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
